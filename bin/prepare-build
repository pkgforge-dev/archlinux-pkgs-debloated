#!/bin/sh

echo "------------------------------------------------------------"
echo "Installing basic packages..."
pacman-key --init
pacman -Syy --noconfirm archlinux-keyring
pacman -Syu --noconfirm \
	base-devel \
	ccache     \
	clang      \
	cmake      \
	curl       \
	git        \
	ninja      \
	sccache    \
	wget

echo "------------------------------------------------------------"
echo "Settings up build options..."
cp -v ./aux/makepkg.conf."$(uname -m)" /etc/makepkg.conf
cat /etc/makepkg.conf

echo "------------------------------------------------------------"
echo "Hacking makepkg to allow building as root in the container..."
sed -i 's|EUID == 0|EUID == 69|g' /usr/bin/makepkg
mkdir -p /usr/local/bin
cp /usr/bin/makepkg /usr/local/bin
echo "------------------------------------------------------------"

# workaround crates.io blocking curl
cat > /usr/local/bin/curl-ua << 'EOF'
#!/bin/sh
exec /usr/bin/curl -A "nixpkgs-fetchCargoVendor/2 (https://github.com/NixOS/nixpkgs)" "$@"
EOF
chmod +x /usr/local/bin/curl-ua

sed -i 's|https::/usr/bin/curl |https::/usr/local/bin/curl-ua |' /etc/makepkg.conf

echo "------------------------------------------------------------"
echo "Setting up swap..."
if [ ! -e /swapfile2 ]; then
	fallocate -l 3G /swapfile2 || dd if=/dev/zero of=/swapfile2 bs=1M count=3072
	chmod 600 /swapfile2
	mkswap /swapfile2
	swapon /swapfile2
fi
free -h
swapon --show
