#!/bin/sh
# Remove functions and strings from a PKGBUILD
#  * Deletes any function that contains the given string
#  * Removes all occurrences of the string from the PKGBUILD

set -e

if [ ! -f "$PKGBUILD" ]; then
	>&2 echo "ERROR: PKGBUILD env var is not set or file not found"
	exit 1
fi

for FUNC do
	LC_ALL=C awk -v func="$FUNC" '
	BEGIN {
		in_func = 0   # 0=outside, 1=waiting for "{", 2=inside body
		depth = 0
		is_target = 0
		target_pat = "^[[:space:]]*[a-zA-Z0-9_-]*" func "[a-zA-Z0-9_-]*\\(\\)"
		any_func   = "^[[:space:]]*[a-zA-Z0-9_-]+\\(\\)"
	}

	in_func == 0 {
		if ($0 ~ target_pat) {
			is_target = 1
			tmp = $0
			opens = gsub(/\{/, "&", tmp)
			closes = gsub(/\}/, "&", tmp)
			if (opens > 0) {
				depth = opens - closes
				in_func = (depth > 0) ? 2 : 0
			} else {
				in_func = 1
			}
			next
		}
		if ($0 ~ any_func) {
			is_target = 0
			tmp = $0
			opens = gsub(/\{/, "&", tmp)
			closes = gsub(/\}/, "&", tmp)
			if (opens > 0) {
				depth = opens - closes
				in_func = (depth > 0) ? 2 : 0
			} else {
				in_func = 1
			}
			print
			next
		}
		gsub(func, "")
		print
	}

	in_func == 1 {
		tmp = $0
		opens = gsub(/\{/, "&", tmp)
		closes = gsub(/\}/, "&", tmp)
		if (opens > 0) {
			depth = opens - closes
			in_func = (depth > 0) ? 2 : 0
		}
		if (! is_target) print
	}

	in_func == 2 {
		tmp = $0
		opens = gsub(/\{/, "&", tmp)
		closes = gsub(/\}/, "&", tmp)
		depth += opens - closes
		if (! is_target) print
		if (depth <= 0) {
			in_func = 0
			depth = 0
			is_target = 0
		}
	}
	' "$PKGBUILD" > "$PKGBUILD.tmp" && mv "$PKGBUILD.tmp" "$PKGBUILD"

	echo "Removed $FUNC"
done
